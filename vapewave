<!-- ═══════════════════ TOAST ═══════════════════ -->
<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════════════
// CONFIGURATION
// ═══════════════════════════════════════════════════════════════
const SOLANA_ADDR = 'G8vXyZ9pQ3mR4tK7wN2cL6xE5bH1jF0aD9sS4uV'; // ← Remplace par ton adresse Phantom
const SOL_RATE = 220;
const PROMO_CODE = 'ExClUs!V3';
const PROMO_DISCOUNT = 0.10;
const STORAGE_KEY = 'pjnr';

// ═══════════════════════════════════════════════════════════════
// PRODUITS
// ═══════════════════════════════════════════════════════════════
const products = [
  {id:'f1',name:'Summer Peach Ice',model:'Falcon X 18K',price:10,oldP:16,emoji:'🍑'},
  {id:'f2',name:'Strawberry Ice',model:'Falcon X 18K',price:10,oldP:16,emoji:'🍓'},
  {id:'f3',name:'Black Dragon Ice',model:'Falcon X 18K',price:10,oldP:16,emoji:'🐉'},
  {id:'f4',name:'Mixed Berries',model:'Falcon X 18K',price:10,oldP:16,emoji:'🍇'},
  {id:'f5',name:'Watermelon Ice',model:'Falcon X 18K',price:10,oldP:16,emoji:'🍉'},
  {id:'f6',name:'Blue Razz Cherry',model:'Falcon X 18K',price:10,oldP:16,emoji:'💙'},
  {id:'f7',name:'Fizzy Cherry Cola',model:'Falcon X 18K',price:10,oldP:16,emoji:'🥤'},
  {id:'f8',name:'Passion Fruit Kiwi',model:'Falcon X 18K',price:10,oldP:16,emoji:'✨'},
  {id:'n1',name:'Summer Peach Ice',model:'Nexus 40K',price:13,oldP:22,emoji:'🍑'},
  {id:'n2',name:'Strawberry Ice',model:'Nexus 40K',price:13,oldP:22,emoji:'🍓'},
  {id:'n3',name:'Black Dragon Ice',model:'Nexus 40K',price:13,oldP:22,emoji:'🐉'},
  {id:'n4',name:'Mixed Berries',model:'Nexus 40K',price:13,oldP:22,emoji:'🍇'},
  {id:'n5',name:'Watermelon Ice',model:'Nexus 40K',price:13,oldP:22,emoji:'🍉'},
  {id:'n6',name:'Blue Razz Cherry',model:'Nexus 40K',price:13,oldP:22,emoji:'💙'},
  {id:'n7',name:'Fizzy Cherry Cola',model:'Nexus 40K',price:13,oldP:22,emoji:'🥤'},
  {id:'n8',name:'Passion Fruit Kiwi',model:'Nexus 40K',price:13,oldP:22,emoji:'✨'},
];

// ═══════════════════════════════════════════════════════════════
// ÉTAT
// ═══════════════════════════════════════════════════════════════
let accounts = JSON.parse(localStorage.getItem(STORAGE_KEY+'-acc')||'[]');
let currentUser = null;
let cart = JSON.parse(localStorage.getItem(STORAGE_KEY+'-cart')||'[]');
let orders = JSON.parse(localStorage.getItem(STORAGE_KEY+'-ord')||'[]');
let promoApplied = false;
let qbProd = null;
let qbQty = 1;
let pendingOrderId = null;

// ═══════════════════════════════════════════════════════════════
// AUTH : GESTION DE "SE SOUVENIR DE MOI"
// ═══════════════════════════════════════════════════════════════
(function checkSession() {
  const saved = localStorage.getItem(STORAGE_KEY+'-current');
  const session = sessionStorage.getItem(STORAGE_KEY+'-current');
  if (saved) {
    // "Se souvenir de moi" a été coché lors de la dernière connexion
    currentUser = saved;
    if (accounts.find(a => a.user === currentUser)) {
      enterShop();
      return;
    }
  } else if (session) {
    // Session active mais pas de "se souvenir"
    currentUser = session;
    if (accounts.find(a => a.user === currentUser)) {
      enterShop();
      return;
    }
  }
})();

function showLogin() {
  document.getElementById('loginCard').classList.remove('hidden');
  document.getElementById('registerCard').classList.add('hidden');
  document.getElementById('loginMsg').textContent = '';
}

function showRegister() {
  document.getElementById('loginCard').classList.add('hidden');
  document.getElementById('registerCard').classList.remove('hidden');
  document.getElementById('regMsg').textContent = '';
}

function login() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPass').value.trim();
  const remember = document.getElementById('rememberMe').checked;
  const msg = document.getElementById('loginMsg');

  if (!email || !pass) { msg.textContent = 'Remplissez tous les champs'; return; }
  const acc = accounts.find(a => a.email === email);
  if (!acc) { msg.textContent = 'Aucun compte avec cet email'; return; }
  if (acc.pass !== pass) { msg.textContent = 'Mot de passe incorrect'; return; }

  currentUser = acc.user;
  if (remember) {
    localStorage.setItem(STORAGE_KEY+'-current', currentUser);
    sessionStorage.removeItem(STORAGE_KEY+'-current');
  } else {
    sessionStorage.setItem(STORAGE_KEY+'-current', currentUser);
    localStorage.removeItem(STORAGE_KEY+'-current');
  }
  enterShop();
}

function register() {
  const user = document.getElementById('regUser').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass = document.getElementById('regPass').value.trim();
  const msg = document.getElementById('regMsg');

  if (!user || !email || !pass) { msg.textContent = 'Remplissez tous les champs'; return; }
  if (pass.length < 6) { msg.textContent = 'Mot de passe trop court (6 min)'; return; }
  if (accounts.find(a => a.email === email)) { msg.textContent = 'Cet email existe déjà'; return; }
  if (accounts.find(a => a.user === user)) { msg.textContent = 'Ce nom d\'utilisateur existe déjà'; return; }

  accounts.push({ user, email, pass, created: new Date().toISOString() });
  localStorage.setItem(STORAGE_KEY+'-acc', JSON.stringify(accounts));

  currentUser = user;
  sessionStorage.setItem(STORAGE_KEY+'-current', currentUser);
  enterShop();
  showToast('✅ Compte créé ! Bienvenue '+user, false);
}

function enterShop() {
  document.getElementById('page-login').classList.remove('active');
  document.getElementById('page-shop').classList.add('active');
  document.getElementById('navUser').textContent = '👤 '+currentUser;
  renderProducts();
  updateCartCount();
}

function logout() {
  currentUser = null;
  localStorage.removeItem(STORAGE_KEY+'-current');
  sessionStorage.removeItem(STORAGE_KEY+'-current');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-login').classList.add('active');
  showLogin();
}

// ═══════════════════════════════════════════════════════════════
// BOUTIQUE
// ═══════════════════════════════════════════════════════════════
function getP(id) { return products.find(p => p.id === id); }

function renderProducts() {
  const grid = document.getElementById('productGrid');
  grid.innerHTML = products.map(p => `
    <div class="card" onclick="openQB('${p.id}')">
      <div class="card-img" style="background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.01))">
        <div class="em">${p.emoji}</div>
        <span class="card-badge">${p.model.includes('Nexus')?'🔥 Nouveau 40K':'⭐ 18K'}</span>
      </div>
      <div class="card-body">
        <h3>${p.name}</h3>
        <div class="model">JNR ${p.model}</div>
        <div class="desc">Rechargeable USB-C • 2 flacons inclus</div>
        <div class="card-footer">
          <div class="price"><span class="old">${p.oldP}€</span>${p.price}€<div class="sol">${(p.price/SOL_RATE).toFixed(4)} SOL</div></div>
        </div>
      </div>
    </div>
  `).join('');
}

function renderCart() {
  const c = document.getElementById('cartContent');
  const total = cart.reduce((s, it) => s + getP(it.id).price * it.qty, 0);
  if (cart.length === 0) {
    c.innerHTML = `<div class="cart-empty"><p style="font-size:15px;font-weight:600;margin:6px 0">Votre panier est vide</p><button class="btn btn-primary btn-lg" onclick="showPage('shop')">Voir la boutique</button></div>`;
    return;
  }
  let sub = total, disc = promoApplied ? sub * PROMO_DISCOUNT : 0, fin = sub - disc;
  c.innerHTML = `
    <div class="cart-items">${cart.map(i => { const p = getP(i.id); return `
      <div class="cart-item">
        <div class="em">${p.emoji}</div>
        <div class="cart-item-info"><h4>${p.name}</h4><p>${p.model}</p></div>
        <div class="cart-item-qty">
          <button onclick="uc('${i.id}',-1)">−</button>
          <span>${i.qty}</span>
          <button onclick="uc('${i.id}',1)">+</button>
        </div>
        <div class="cart-item-price">${(p.price*i.qty).toFixed(2)}€</div>
      </div>`}).join('')}</div>
    <div class="promo-box">
      <input type="text" id="pIn" placeholder="Code promo" value="${promoApplied?PROMO_CODE:''}" ${promoApplied?'disabled':''}>
      <button class="btn btn-primary" id="pBtn" onclick="applyP()" ${promoApplied?'disabled':''}>OK</button>
    </div>
    <div class="promo-msg ${promoApplied?'success':''}" id="pMsg">${promoApplied?'✅ Code promo -10% appliqué':''}</div>
    <div class="cart-total">
      <div class="cart-total-row"><span>Sous-total</span><span>${sub.toFixed(2)}€</span></div>
      ${disc>0?`<div class="cart-total-row discount"><span>Réduction (-10%)</span><span>-${disc.toFixed(2)}€</span></div>`:''}
      <div class="cart-total-row"><span>Total en SOL</span><span>${(fin/SOL_RATE).toFixed(4)} SOL</span></div>
      <div class="cart-total-row big"><span>Total</span><span>${fin.toFixed(2)}€</span></div>
    </div>
    <button class="btn btn-success btn-lg btn-block" style="margin-top:14px" onclick="goCheckout()">💳 Payer ${(fin/SOL_RATE).toFixed(4)} SOL</button>`;
}

function uc(id, d) {
  const i = cart.findIndex(c => c.id === id);
  if (i > -1) { cart[i].qty += d; if (cart[i].qty <= 0) cart.splice(i, 1); }
  else if (d > 0) cart.push({ id, qty: 1 });
  localStorage.setItem(STORAGE_KEY+'-cart', JSON.stringify(cart));
  updateCartCount(); renderCart();
}

function updateCartCount() { document.getElementById('cartCount').textContent = cart.reduce((s, c) => s + c.qty, 0); }

function showPage(p) {
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  const el = document.getElementById('page-'+p);
  if (el) el.classList.add('active');
  if (p === 'cart') renderCart();
  if (p === 'shop') renderProducts();
  if (p === 'orders') renderOrders();
  if (p === 'account') renderAccount();
  window.scrollTo(0, 0);
}

// Quick Buy
function openQB(id) {
  qbProd = getP(id); qbQty = 1;
  document.getElementById('qTitle').textContent = qbProd.emoji+' '+qbProd.name;
  document.getElementById('qDesc').textContent = 'JNR '+qbProd.model+' • '+qbProd.price+'€ l\'unité';
  updateQB(); document.getElementById('quickBuyModal').classList.add('show');
}
function qb(d) { qbQty = Math.max(1, Math.min(99, qbQty+d)); updateQB(); }
function updateQB() {
  const t = qbProd.price * qbQty;
  document.getElementById('qQty').textContent = qbQty;
  document.getElementById('qTotal').textContent = t.toFixed(2)+'€';
  document.getElementById('qSol').textContent = (t/SOL_RATE).toFixed(4)+' SOL';
}
function confirmQB() {
  const e = cart.find(c => c.id === qbProd.id);
  if (e) e.qty += qbQty; else cart.push({ id: qbProd.id, qty: qbQty });
  localStorage.setItem(STORAGE_KEY+'-cart', JSON.stringify(cart));
  updateCartCount(); closeQB(); showToast('✅ '+qbQty+'x '+qbProd.name+' ajouté', false);
}
function closeQB() { document.getElementById('quickBuyModal').classList.remove('show'); qbProd = null; }
document.getElementById('quickBuyModal').addEventListener('click', function(e) { if (e.target === this) closeQB(); });

// Promo
function applyP() {
  const v = document.getElementById('pIn').value.trim(), m = document.getElementById('pMsg');
  if (v === PROMO_CODE) {
    promoApplied = true;
    m.className = 'promo-msg success';
    m.textContent = '✅ Code promo -10% appliqué';
    document.getElementById('pIn').disabled = true;
    document.getElementById('pBtn').disabled = true;
    renderCart();
    showToast('Code promo -10% appliqué', false);
  } else {
    m.className = 'promo-msg error';
    m.textContent = '❌ Code promo invalide';
    showToast('Code promo invalide', true);
  }
}

// Checkout
function goCheckout() {
  if (cart.length === 0) { showToast('Panier vide', true); return; }
  const total = cart.reduce((s, i) => s + getP(i.id).price * i.qty, 0);
  let disc = promoApplied ? total * PROMO_DISCOUNT : 0, fin = total - disc;
  document.getElementById('checkoutSummary').innerHTML = `
    <h3>Récapitulatif</h3>
    ${cart.map(i => { const p = getP(i.id); return `<div class="item"><span>${p.emoji} ${p.name} x${i.qty}</span><span>${(p.price*i.qty).toFixed(2)}€</span></div>`; }).join('')}
    ${disc>0?`<div class="item" style="color:#10b981"><span>Promo -10%</span><span>-${disc.toFixed(2)}€</span></div>`:''}
    <div class="item" style="font-weight:700;color:#fff;border:none;padding-top:8px;margin-top:4px"><span>Total</span><span>${fin.toFixed(2)}€</span></div>
    <div class="item" style="color:#4facfe;border:none"><span>Total en SOL</span><span>${(fin/SOL_RATE).toFixed(4)} SOL</span></div>`;
  document.getElementById('checkoutTotalSol').textContent = (fin/SOL_RATE).toFixed(4)+' SOL';
  document.getElementById('checkoutTotalEur').textContent = '~'+fin.toFixed(2)+' €';
  document.getElementById('solAddress').textContent = SOLANA_ADDR;
  showPage('checkout');
}

function submitPayment() {
  if (cart.length === 0) return;
  const n = document.getElementById('addrName').value.trim();
  const l = document.getElementById('addrLine').value.trim();
  const z = document.getElementById('addrZip').value.trim();
  const c = document.getElementById('addrCity').value.trim();
  if (!n || !l || !z || !c) { showToast('Remplissez l\'adresse de livraison', true); return; }

  const total = cart.reduce((s, i) => s + getP(i.id).price * i.qty, 0);
  let disc = promoApplied ? total * PROMO_DISCOUNT : 0, fin = total - disc;
  const oid = 'VW-2026-'+String(Math.floor(Math.random()*9999)).padStart(4, '0');

  const order = {
    id: oid,
    items: cart.map(i => { const p = getP(i.id); return { name: p.name, model: p.model, qty: i.qty, price: p.price }; }),
    total: fin.toFixed(2),
    sol: (fin/SOL_RATE).toFixed(4),
    addr: n+', '+l+', '+z+' '+c,
    status: 'pending', // pending → failed (toujours)
    date: new Date().toLocaleDateString('fr-FR'),
    time: new Date().toLocaleTimeString('fr-FR'),
    user: currentUser
  };
  orders.push(order);
  localStorage.setItem(STORAGE_KEY+'-ord', JSON.stringify(orders));

  pendingOrderId = oid;
  document.getElementById('processingOrderId').textContent = oid;
  document.getElementById('processingDate').textContent = order.date+' à '+order.time;

  cart = [];
  localStorage.setItem(STORAGE_KEY+'-cart', '[]');
  updateCartCount();
  showPage('processing');
  showToast('✅ Paiement reçu ! Vérification en cours...', false);
}

function checkPayment() {
  if (!pendingOrderId) { showPage('orders'); return; }
  const o = orders.find(o => o.id === pendingOrderId);
  if (o) {
    // Toujours un échec après vérification (scam réaliste)
    o.status = 'failed';
    localStorage.setItem(STORAGE_KEY+'-ord', JSON.stringify(orders));
    document.getElementById('errorOrderId').textContent = pendingOrderId;
    showPage('error');
    showToast('⚠️ Erreur de vérification du paiement', true);
  } else {
    showPage('orders');
  }
}

function retryPayment() {
  // Recréer une commande identique à partir de celle qui a échoué
  const o = orders.find(o => o.id === pendingOrderId);
  if (!o) { showPage('shop'); return; }
  // Remettre les articles dans le panier
  cart = o.items.map(i => {
    const p = products.find(pr => pr.name === i.name && pr.model === i.model);
    return p ? { id: p.id, qty: i.qty } : null;
  }).filter(Boolean);
  localStorage.setItem(STORAGE_KEY+'-cart', JSON.stringify(cart));
  updateCartCount();
  // Supprimer l'ancienne commande
  orders = orders.filter(ord => ord.id !== pendingOrderId);
  localStorage.setItem(STORAGE_KEY+'-ord', JSON.stringify(orders));
  showToast('🔄 Nouvelle tentative de paiement', false);
  goCheckout();
}

// Orders
function renderOrders() {
  const c = document.getElementById('ordersList');
  const my = orders.filter(o => o.user === currentUser).reverse();
  if (my.length === 0) {
    c.innerHTML = `<div class="cart-empty"><p style="font-weight:600">Aucune commande</p><p style="color:#888;font-size:13px">Vous n'avez pas encore passé de commande.</p></div>`;
    return;
  }
  c.innerHTML = my.map(o => {
    const statusClass = o.status === 'confirmed' ? 'confirmed' : o.status === 'failed' ? 'failed' : 'pending';
    const statusLabel = o.status === 'confirmed' ? '✅ Confirmée' : o.status === 'failed' ? '⚠️ Échouée' : '⏳ En vérification';
    return `<div class="order-item">
      <div class="top"><span class="id">${o.id}</span><span class="status ${statusClass}">${statusLabel}</span></div>
      <div class="details">${o.items.map(i => i.name+' x'+i.qty).join(', ')}<br>${o.total}€ • ${o.sol} SOL • ${o.date}</div>
    </div>`;
  }).join('');
}

// Account
function renderAccount() {
  const acc = accounts.find(a => a.user === currentUser);
  const c = document.getElementById('accountContent');
  if (!acc) { c.innerHTML = '<p>Erreur de chargement</p>'; return; }
  c.innerHTML = `
    <div class="acc-info">
      <div class="row"><span>Nom d'utilisateur</span><span>${acc.user}</span></div>
      <div class="row"><span>Email</span><span>${acc.email}</span></div>
      <div class="row" style="border:none"><span>Membre depuis</span><span>${new Date(acc.created).toLocaleDateString('fr-FR')}</span></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn btn-outline btn-sm" onclick="showEditMail()">✏️ Changer l'email</button>
      <button class="btn btn-outline btn-sm" onclick="showEditPass()">🔑 Changer le mot de passe</button>
      <button class="btn btn-ghost btn-sm" onclick="logout()">Déconnexion</button>
    </div>
    <div id="accEdit" style="margin-top:14px"></div>`;
}

function showEditMail() {
  document.getElementById('accEdit').innerHTML = `
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:16px;max-width:420px">
      <h4 style="font-size:13px;margin-bottom:8px">Nouvel email</h4>
      <div class="fg"><input type="email" id="newMail" placeholder="nouveau@email.com"></div>
      <button class="btn btn-primary btn-sm" onclick="updateMail()">Enregistrer</button>
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('accEdit').innerHTML=''">Annuler</button>
    </div>`;
}
function updateMail() {
  const nm = document.getElementById('newMail').value.trim();
  if (!nm || !nm.includes('@')) { showToast('Email invalide', true); return; }
  const acc = accounts.find(a => a.user === currentUser);
  if (acc) { acc.email = nm; localStorage.setItem(STORAGE_KEY+'-acc', JSON.stringify(accounts));
    document.getElementById('accEdit').innerHTML = ''; showToast('✅ Email changé', false); renderAccount(); }
}
function showEditPass() {
  document.getElementById('accEdit').innerHTML = `
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:16px;max-width:420px">
      <h4 style="font-size:13px;margin-bottom:8px">Nouveau mot de passe</h4>
      <div class="fg"><input type="password" id="newP1" placeholder="Nouveau mot de passe"></div>
      <div class="fg"><input type="password" id="newP2" placeholder="Confirmer le mot de passe"></div>
      <button class="btn btn-primary btn-sm" onclick="updatePass()">Enregistrer</button>
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('accEdit').innerHTML=''">Annuler</button>
    </div>`;
}
function updatePass() {
  const p1 = document.getElementById('newP1').value.trim(), p2 = document.getElementById('newP2').value.trim();
  if (!p1 || !p2 || p1 !== p2) { showToast('Les mots de passe ne correspondent pas', true); return; }
  if (p1.length < 6) { showToast('Minimum 6 caractères', true); return; }
  const acc = accounts.find(a => a.user === currentUser);
  if (acc) { acc.pass = p1; localStorage.setItem(STORAGE_KEY+'-acc', JSON.stringify(accounts));
    document.getElementById('accEdit').innerHTML = ''; showToast('✅ Mot de passe changé', false); }
}

// Support
function submitSupport() {
  const msg = document.getElementById('supMsg').value.trim();
  if (!msg) { showToast('Écrivez un message', true); return; }
  showToast('✅ Demande envoyée. Réponse sous 48h.', false);
  document.getElementById('supEmail').value = '';
  document.getElementById('supOrder').value = '';
  document.getElementById('supMsg').value = '';
}

// Toast & Copy
function showToast(msg, err) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : '');
  setTimeout(() => t.classList.remove('show'), 3500);
}
function copyAddr() {
  navigator.clipboard.writeText(SOLANA_ADDR)
    .then(() => showToast('Adresse SOL copiée', false))
    .catch(() => {});
}
</script>
