<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Puffs JNR – Boutique officielle</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:#0a0a0f;color:#fff;min-height:100vh;display:flex;flex-direction:column}
a{text-decoration:none;color:inherit}

/* ─── PAGES ─── */
.page{display:none;animation:fade .25s ease}
.page.active{display:block}
@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ─── LOGIN ─── */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:radial-gradient(ellipse at 50% 0,rgba(79,172,254,.08)0,transparent 60%)}
.login-box{width:100%;max-width:400px}
.logo{text-align:center;margin-bottom:28px}
.logo h1{font-size:30px;font-weight:800;background:linear-gradient(135deg,#00f2fe,#4facfe);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.5px}
.logo p{color:#666;font-size:13px;margin-top:4px}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:28px;backdrop-filter:blur(8px)}
.card h2{font-size:20px;font-weight:700;margin-bottom:2px}
.card .sub{color:#888;font-size:13px;margin-bottom:20px}
.fg{margin-bottom:14px}
.fg label{display:block;font-size:12px;color:#aaa;margin-bottom:4px;font-weight:500}
.fg input{width:100%;padding:11px 14px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff;font-size:14px;font-family:inherit;outline:none;transition:border .2s}
.fg input:focus{border-color:#4facfe}
.fg input::placeholder{color:#444}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:12px 24px;border:none;border-radius:10px;font-weight:600;font-size:14px;cursor:pointer;font-family:inherit;transition:all .2s;gap:6px}
.btn-block{width:100%}
.btn-lg{padding:14px 28px;font-size:15px;border-radius:10px}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:7px}
.btn-primary{background:linear-gradient(135deg,#00f2fe,#4facfe);color:#000}
.btn-primary:hover{transform:scale(1.02);box-shadow:0 8px 24px rgba(79,172,254,.3)}
.btn-outline{background:transparent;border:1px solid rgba(255,255,255,.15);color:#fff}
.btn-outline:hover{background:rgba(255,255,255,.06)}
.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,.08);color:#999}
.btn-ghost:hover{border-color:rgba(255,255,255,.2);color:#fff}
.btn-success{background:#10b981;color:#fff}
.btn-success:hover{background:#059669}
.switch-action{text-align:center;margin-top:14px;font-size:13px;color:#888}
.switch-action a{color:#4facfe;cursor:pointer;font-weight:600;font-family:inherit;font-size:13px;background:none;border:none}
.msg{font-size:12px;margin-top:6px;min-height:18px;text-align:center;line-height:1.4}
.msg.success{color:#10b981}
.msg.error{color:#ef4444}
.hidden{display:none}
.remember-row{display:flex;align-items:center;gap:8px;margin:12px 0 16px;font-size:13px;color:#999}
.remember-row input[type=checkbox]{accent-color:#4facfe;width:16px;height:16px;cursor:pointer}
.remember-row label{cursor:pointer}

/* ─── NAVBAR ─── */
.nav{position:sticky;top:0;z-index:100;background:rgba(10,10,15,.95);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.06);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.nav-logo{font-weight:800;font-size:19px;letter-spacing:-.5px;background:linear-gradient(135deg,#00f2fe,#4facfe);-webkit-background-clip:text;-webkit-text-fill-color:transparent;cursor:pointer}
.nav-links{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.nav-links a,.nav-links button{color:#aaa;font-size:12px;font-weight:500;cursor:pointer;background:none;border:none;font-family:inherit;padding:5px 9px;border-radius:7px;transition:all .2s}
.nav-links a:hover,.nav-links button:hover{color:#fff;background:rgba(255,255,255,.05)}
.nav-cart{position:relative}
.cart-count{position:absolute;top:-7px;right:-8px;background:#4facfe;color:#000;font-size:9px;font-weight:700;width:17px;height:17px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.nav-user{color:#4facfe!important;font-weight:600!important}
.nav-divider{width:1px;height:16px;background:rgba(255,255,255,.08);margin:0 4px}

/* ─── HERO ─── */
.hero{text-align:center;padding:56px 24px 40px;background:radial-gradient(ellipse at 50% 0,rgba(79,172,254,.08)0,transparent 60%)}
.hero h1{font-size:34px;font-weight:800;margin-bottom:6px;letter-spacing:-.5px}
.hero h1 span{background:linear-gradient(135deg,#00f2fe,#4facfe);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero p{color:#888;font-size:14px;max-width:440px;margin:0 auto 8px}
.hero .badge{display:inline-flex;align-items:center;gap:5px;padding:5px 16px;background:rgba(79,172,254,.08);border:1px solid rgba(79,172,254,.2);border-radius:50px;font-size:11px;color:#4facfe;font-weight:600}

/* ─── SECTIONS ─── */
.section{max-width:1120px;margin:0 auto;padding:24px}
.section-title{font-size:20px;font-weight:700;margin-bottom:18px}
.section-title small{display:block;color:#666;font-size:12px;font-weight:400;margin-top:3px}

/* ─── PRODUCT GRID ─── */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:16px}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:14px;overflow:hidden;cursor:pointer;transition:all .3s}
.card:hover{transform:translateY(-4px);border-color:rgba(79,172,254,.25);box-shadow:0 16px 48px rgba(79,172,254,.06)}
.card-img{width:100%;aspect-ratio:1;display:flex;align-items:center;justify-content:center;padding:20px;position:relative}
.card-img .em{font-size:52px}
.card-badge{position:absolute;top:8px;left:8px;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);padding:3px 8px;border-radius:6px;font-size:10px;font-weight:600;color:#4facfe;border:1px solid rgba(79,172,254,.15)}
.card-body{padding:12px 15px 15px}
.card-body h3{font-size:13px;font-weight:600;margin-bottom:1px}
.card-body .model{color:#666;font-size:10px;margin-bottom:4px}
.card-body .desc{color:#888;font-size:10px;margin-bottom:8px;line-height:1.4}
.card-footer{display:flex;align-items:center;justify-content:space-between}
.price{font-size:15px;font-weight:700}
.price .sol{color:#4facfe;font-size:11px;font-weight:600}
.price .old{color:#666;font-size:11px;text-decoration:line-through;margin-right:4px;font-weight:400}

/* ─── CART ─── */
.cart-items{display:flex;flex-direction:column;gap:8px}
.cart-item{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:11px}
.cart-item .em{font-size:22px;width:34px;text-align:center;flex-shrink:0}
.cart-item-info{flex:1;min-width:0}
.cart-item-info h4{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cart-item-info p{color:#888;font-size:10px}
.cart-item-qty{display:flex;align-items:center;gap:3px;flex-shrink:0}
.cart-item-qty button{width:22px;height:22px;border:1px solid rgba(255,255,255,.1);background:transparent;color:#fff;border-radius:5px;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.cart-item-qty button:hover{background:rgba(255,255,255,.08)}
.cart-item-qty span{min-width:18px;text-align:center;font-weight:600;font-size:13px}
.cart-item-price{font-weight:700;font-size:13px;min-width:48px;text-align:right;flex-shrink:0}
.cart-empty{text-align:center;padding:48px 20px;color:#666}

.promo-box{display:flex;gap:6px;margin:12px 0}
.promo-box input{flex:1;padding:8px 12px;border-radius:7px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border .2s}
.promo-box input:focus{border-color:#4facfe}
.promo-box input::placeholder{color:#444}
.promo-msg{font-size:11px;margin-top:3px;min-height:16px}
.promo-msg.success{color:#10b981}
.promo-msg.error{color:#ef4444}

.cart-total{margin-top:14px;padding:16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px}
.cart-total-row{display:flex;justify-content:space-between;margin-bottom:3px;font-size:12px;color:#999}
.cart-total-row.big{font-size:16px;font-weight:700;color:#fff;margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,.06)}
.cart-total-row.discount{color:#10b981}

/* ─── CHECKOUT ─── */
.checkout-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start}
@media(max-width:768px){.checkout-grid{grid-template-columns:1fr}}
.checkout-summary{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:20px}
.checkout-summary h3{font-size:14px;margin-bottom:12px}
.checkout-summary .item{display:flex;justify-content:space-between;padding:5px 0;font-size:12px;color:#ccc}
.checkout-summary .item+.item{border-top:1px solid rgba(255,255,255,.04)}
.checkout-pay{text-align:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:24px}
.checkout-pay .big-sol{font-size:32px;font-weight:800;background:linear-gradient(135deg,#00f2fe,#4facfe);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.checkout-pay .sub{color:#666;font-size:12px;margin:3px 0 14px}
.qr-box{width:160px;height:160px;margin:14px auto;background:#fff;border-radius:14px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px;color:#999;font-size:11px;gap:4px}
.qr-box .big{font-size:36px;color:#000}
.sol-addr{background:rgba(255,255,255,.04);padding:8px 12px;border-radius:6px;font-family:monospace;font-size:10px;color:#888;word-break:break-all;border:1px solid rgba(255,255,255,.06);cursor:pointer;margin-top:8px;transition:all .2s}
.sol-addr:hover{border-color:#4facfe;color:#fff}

/* ─── ADDRESS FORM ─── */
.addr-box{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:18px;margin-bottom:14px}
.addr-box h3{font-size:13px;margin-bottom:12px}
.addr-row{display:flex;gap:8px}
.addr-row .fg{flex:1}

/* ─── STATUS PAGES ─── */
.confirm-box{text-align:center;max-width:420px;margin:48px auto;padding:36px 24px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:18px}
.confirm-box .icon{font-size:42px;margin-bottom:10px}
.confirm-box h2{font-size:20px;margin-bottom:4px}
.confirm-box p{color:#888;font-size:13px;margin-bottom:2px;line-height:1.5}
.confirm-box .id{color:#555;font-size:11px;margin-top:10px;font-family:monospace}

/* ─── ORDER ITEM ─── */
.order-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:14px;margin-bottom:10px}
.order-item .top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}
.order-item .id{font-weight:600;font-size:12px}
.order-item .status{font-size:10px;padding:3px 8px;border-radius:14px;font-weight:600}
.order-item .status.pending{background:rgba(234,179,8,.12);color:#eab308}
.order-item .status.failed{background:rgba(239,68,68,.12);color:#ef4444}
.order-item .status.confirmed{background:rgba(16,185,129,.12);color:#10b981}
.order-item .details{color:#888;font-size:10px;line-height:1.5}

/* ─── ACCOUNT ─── */
.acc-info{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:18px;max-width:440px}
.acc-info .row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.acc-info .row:last-child{border:none}
.acc-info .row span:first-child{color:#888}
.acc-info .row span:last-child{color:#fff;font-weight:500}

/* ─── SUPPORT ─── */
.support-box{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:20px;max-width:480px}
.support-box textarea{resize:vertical;min-height:80px;width:100%;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff;font-size:13px;font-family:inherit;outline:none}
.support-box textarea:focus{border-color:#4facfe}
.support-box select{width:100%;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff;font-size:13px;font-family:inherit;outline:none}
.support-box select:focus{border-color:#4facfe}
.support-box select option{background:#1a1a2e;color:#fff}

/* ─── MODAL ─── */
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:300;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.show{display:flex}
.modal{background:#15152a;border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:28px;max-width:380px;width:100%;animation:fade .2s ease}
.modal h2{font-size:16px;margin-bottom:2px}
.modal p{color:#888;font-size:12px;margin-bottom:12px}
.qty-ctl{display:flex;align-items:center;justify-content:center;gap:12px;margin:16px 0}
.qty-ctl button{width:34px;height:34px;border:1px solid rgba(255,255,255,.12);background:transparent;color:#fff;border-radius:8px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.qty-ctl button:hover{background:rgba(255,255,255,.06)}
.qty-ctl span{font-size:24px;font-weight:700;min-width:32px;text-align:center}

/* ─── TOAST ─── */
.toast{position:fixed;bottom:20px;right:20px;background:rgba(16,185,129,.95);color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;font-weight:600;transform:translateY(100px);opacity:0;transition:all .4s cubic-bezier(.22,1,.36,1);z-index:400;pointer-events:none;max-width:340px}
.toast.show{transform:translateY(0);opacity:1}
.toast.error{background:rgba(239,68,68,.95)}

/* ─── RESPONSIVE ─── */
@media(max-width:600px){
  .hero h1{font-size:24px}
  .grid{grid-template-columns:1fr 1fr}
  .nav{padding:10px 14px}
  .nav-links a,.nav-links button{font-size:10px;padding:4px 6px}
  .nav-logo{font-size:16px}
  .section{padding:16px}
  .card-body h3{font-size:12px}
  .login-wrap{padding:16px}
}

/* Scrollbar */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.15)}
</style>
</head>
<body>

<!-- ═══════════════════ LOGIN PAGE ═══════════════════ -->
<div class="page active" id="page-login">
  <div class="login-wrap">
    <div class="login-box">
      <div class="logo">
        <h1>⟠ Puffs JNR</h1>
        <p>Paiement en Solana uniquement</p>
      </div>

      <!-- Connexion -->
      <div class="card" id="loginCard">
        <h2>Connexion</h2>
        <p class="sub">Connectez-vous pour accéder à la boutique</p>
        <div class="fg"><label>Email</label><input type="email" id="loginEmail" placeholder="votre@email.com"></div>
        <div class="fg"><label>Mot de passe</label><input type="password" id="loginPass" placeholder="••••••••"></div>
        <div class="remember-row">
          <input type="checkbox" id="rememberMe" checked>
          <label for="rememberMe">Se souvenir de moi</label>
        </div>
        <div class="msg error" id="loginMsg"></div>
        <button class="btn btn-primary btn-block" onclick="login()">Se connecter</button>
        <div class="switch-action">Pas encore de compte ? <a onclick="showRegister()">Créer un compte</a></div>
      </div>

      <!-- Inscription -->
      <div class="card hidden" id="registerCard">
        <h2>Créer un compte</h2>
        <p class="sub">Inscrivez-vous gratuitement</p>
        <div class="fg"><label>Nom d'utilisateur</label><input type="text" id="regUser" placeholder="Votre pseudo"></div>
        <div class="fg"><label>Email</label><input type="email" id="regEmail" placeholder="votre@email.com"></div>
        <div class="fg"><label>Mot de passe</label><input type="password" id="regPass" placeholder="6 caractères minimum"></div>
        <div class="msg error" id="regMsg"></div>
        <button class="btn btn-primary btn-block" onclick="register()">Créer mon compte</button>
        <div class="switch-action">Déjà un compte ? <a onclick="showLogin()">Se connecter</a></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════ SHOP PAGE ═══════════════════ -->
<div class="page" id="page-shop">
  <nav class="nav">
    <div class="nav-logo" onclick="showPage('shop')">⟠ Puffs JNR</div>
    <div class="nav-links">
      <a onclick="showPage('shop')">Boutique</a>
      <a onclick="showPage('orders')">Commandes</a>
      <a onclick="showPage('account')">Compte</a>
      <a onclick="showPage('cart')" class="nav-cart">Panier <span class="cart-count" id="cartCount">0</span></a>
      <a onclick="showPage('support')">Support</a>
      <span class="nav-divider"></span>
      <button onclick="logout()" class="nav-user" id="navUser">Déconnexion</button>
    </div>
  </nav>

  <div class="hero">
    <h1>Puffs <span>JNR</span></h1>
    <p>Jusqu'à 40 000 puffs – Rechargeables USB-C</p>
    <div class="badge">⟠ Paiement en SOL uniquement</div>
  </div>

  <div class="section">
    <div class="section-title">Nos modèles <small>Livrés avec 2 flacons de 10 ml • Paiement crypto</small></div>
    <div class="grid" id="productGrid"></div>
  </div>
</div>

<!-- ═══════════════════ CART PAGE ═══════════════════ -->
<div class="page" id="page-cart">
  <nav class="nav">
    <div class="nav-logo" onclick="showPage('shop')">⟠ Puffs JNR</div>
    <div class="nav-links">
      <a onclick="showPage('shop')">Boutique</a>
      <a onclick="showPage('orders')">Commandes</a>
      <a onclick="showPage('account')">Compte</a>
      <a onclick="showPage('cart')" class="nav-cart">Panier <span class="cart-count">0</span></a>
      <a onclick="showPage('support')">Support</a>
      <button onclick="logout()" style="color:#4facfe;font-weight:600">Déconnexion</button>
    </div>
  </nav>
  <div class="section" style="max-width:680px">
    <div class="section-title">Votre panier</div>
    <div id="cartContent"></div>
  </div>
</div>

<!-- ═══════════════════ CHECKOUT PAGE ═══════════════════ -->
<div class="page" id="page-checkout">
  <nav class="nav">
    <div class="nav-logo" onclick="showPage('shop')">⟠ Puffs JNR</div>
    <div class="nav-links">
      <a onclick="showPage('cart')">← Retour panier</a>
    </div>
  </nav>
  <div class="section" style="max-width:800px">
    <div class="section-title">Finaliser la commande</div>
    <div class="checkout-grid">
      <div>
        <div class="checkout-summary" id="checkoutSummary"></div>
      </div>
      <div>
        <div class="addr-box">
          <h3>📍 Adresse de livraison</h3>
          <div class="fg"><label>Nom complet</label><input type="text" id="addrName" placeholder="Jean Dupont"></div>
          <div class="fg"><label>Adresse</label><input type="text" id="addrLine" placeholder="12 rue de la Paix"></div>
          <div class="addr-row">
            <div class="fg"><label>Code postal</label><input type="text" id="addrZip" placeholder="75001"></div>
            <div class="fg" style="flex:2"><label>Ville</label><input type="text" id="addrCity" placeholder="Paris"></div>
          </div>
        </div>
        <div class="checkout-pay">
          <p style="color:#888;font-size:11px;margin-bottom:2px">Total à payer</p>
          <div class="big-sol" id="checkoutTotalSol">0 SOL</div>
          <div class="sub" id="checkoutTotalEur">~0 €</div>
          <div class="qr-box"><span class="big">⟠</span>Scannez ou copiez l'adresse</div>
          <p style="color:#888;font-size:10px">Envoyez le montant exact en SOL à :</p>
          <div class="sol-addr" id="solAddress" onclick="copyAddr()">G8vXyZ9pQ3mR4tK7wN2cL6xE5bH1jF0aD9sS4uV</div>
          <button class="btn btn-success btn-lg btn-block" style="margin-top:14px" onclick="submitPayment()">✅ J'ai envoyé les SOL</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════ PROCESSING PAGE ═══════════════════ -->
<div class="page" id="page-processing">
  <nav class="nav"><div class="nav-logo" onclick="showPage('shop')">⟠ Puffs JNR</div></nav>
  <div class="confirm-box">
    <div class="icon">⏳</div>
    <h2>Paiement en cours de vérification</h2>
    <p>Votre transaction SOL est en cours de traitement.</p>
